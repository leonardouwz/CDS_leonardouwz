# .env  –  copy to .env and fill in real values (never commit this file)

# ── MySQL (default) ──────────────────────────────────────────────────────────
# DB_ENGINE=mysql
# DB_USER=root
# DB_PASSWORD=my-secret-pw
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=task_db

# ── PostgreSQL (uncomment block below and comment block above) ───────────────
DB_ENGINE=postgresql
DB_USER=postgres
DB_PASSWORD=my-secret-pw
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=task_db

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=change-this-in-production
